pipeline {
  agent any

  options {
    disableConcurrentBuilds()
  }

  environment {
    IMAGE_NAME  = 'nixonp95/flask-aws-monitor'
    IMAGE_TAG   = "${env.BUILD_NUMBER}"

    APP_DIR = 'projects/Rolling project Integration with Jenkins/Rolling-project-app'
  }

  stages {

    stage('Checkout') {
      steps {
        sh '''#!/usr/bin/env bash
set -euo pipefail
set -x
git rev-parse --short HEAD
'''
      }
    }

    stage('Parallel Checks') {
      parallel {

        stage('Linting') {
          steps {
            sh '''#!/usr/bin/env bash
set -euo pipefail
set -x

cd "${APP_DIR}"

echo "== Python Lint (flake8) =="
# Real linting (install if missing)
python3 -m pip install --no-cache-dir -q flake8 || pip3 install --no-cache-dir -q flake8
# If you want strict mode, remove the '|| true'
flake8 . || true

echo "== ShellCheck (MOCK) =="
echo "ShellCheck: SKIPPED (mock) - OK"

echo "== Hadolint (MOCK) =="
if [ -f Dockerfile ]; then
  echo "Hadolint: SKIPPED (mock) - Dockerfile exists"
else
  echo "Hadolint: Dockerfile not found in ${APP_DIR}"
  exit 1
fi
'''
          }
        }

        stage('Security Scan') {
          steps {
            sh '''#!/usr/bin/env bash
set -euo pipefail
set -x

cd "${APP_DIR}"

echo "== Bandit (Python security) =="
python3 -m pip install --no-cache-dir -q bandit || pip3 install --no-cache-dir -q bandit
# If you want strict mode, remove the '|| true'
bandit -r . || true

echo "== Trivy FS scan (MOCK) =="
echo "Trivy FS: SKIPPED (mock) - OK"
'''
          }
        }

      }
    }

    stage('Build Docker Image') {
      steps {
        sh '''#!/usr/bin/env bash
set -euo pipefail
set -x

cd "${APP_DIR}"

echo "Building ${IMAGE_NAME}:${IMAGE_TAG}"
docker build -t "${IMAGE_NAME}:${IMAGE_TAG}" .
'''
      }
    }

    stage('Trivy Image Scan') {
      steps {
        sh '''#!/usr/bin/env bash
set -euo pipefail
set -x

# Real Trivy image scan (does NOT require mounting workspace)
docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy:latest \
  image --no-progress --severity HIGH,CRITICAL --exit-code 0 "${IMAGE_NAME}:${IMAGE_TAG}"
'''
      }
    }

    stage('Push to Docker Hub') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-creds',
                                          usernameVariable: 'DH_USER',
                                          passwordVariable: 'DH_PASS')]) {
          sh '''#!/usr/bin/env bash
set -euo pipefail
set -x

echo "$DH_PASS" | docker login -u "$DH_USER" --password-stdin

docker push "${IMAGE_NAME}:${IMAGE_TAG}"

docker tag "${IMAGE_NAME}:${IMAGE_TAG}" "${IMAGE_NAME}:latest"
docker push "${IMAGE_NAME}:latest"

docker logout
'''
        }
      }
    }
  }

  post {
    success {
      echo "SUCCESS: Pushed ${IMAGE_NAME}:${IMAGE_TAG} and ${IMAGE_NAME}:latest"
    }
    failure {
      echo "FAILED: Check the logs above."
    }
    always {
      sh '''#!/usr/bin/env bash
set +e
docker ps
docker images | head -n 20
'''
    }
  }
}
